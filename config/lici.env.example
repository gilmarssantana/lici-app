# LICI application configuration template.
# Copy to /root/lici-app/config/lici.env and adjust locally.
# Do not put real secrets here. Secrets belong in /root/lici-app/secrets/*.env.

LICI_APP_NAME="LICI App"
LICI_ENV="production"
LICI_APP_ROOT="/root/lici-app"
LICI_DOCS_ROOT="/root/lici-docs"
LICI_BACKUP_ROOT="/root/backups/lici"

LICI_API_HOST="127.0.0.1"
LICI_API_PORT="8100"
LICI_MEMORY_HOST="127.0.0.1"
LICI_MEMORY_PORT="8010"
LICI_FRONTEND_HOST="127.0.0.1"
LICI_FRONTEND_PORT="5173"
LICI_RAG_HOST="127.0.0.1"
LICI_RAG_PORT="8000"

LICI_PUBLIC_URL="https://licitaprobrasil.com/"
LICI_PUBLIC_DOMAIN="licitaprobrasil.com"

LICI_MEMORY_ROOT="/root/lici-app/memoria_viva"
LICI_AUTH_ROOT="/root/lici-app/auth"
LICI_SECRETS_ROOT="/root/lici-app/secrets"
LICI_LOGS_ROOT="/root/lici-app/logs"
LICI_AUDIT_LOG="/root/lici-app/audit/audit.log"

LICI_BACKUP_MAX_AGE_HOURS="36"
LICI_BACKUP_KEEP_COUNT="7"
